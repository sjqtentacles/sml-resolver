(* MLB for the sml-semver library: the vendored sml-parsec (which brings
 * `structure CharParsec` into scope) followed by the semver sources.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples) can use CharParsec alongside Semver. *)
$(SML_LIB)/basis/basis.mlb
../sml-parsec/parsec.mlb
semver.sig
semver.sml
